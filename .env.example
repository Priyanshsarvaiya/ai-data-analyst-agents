OPENROUTER_API_KEY=your_key_here
OPENROUTER_MODEL=z-ai/glm-5
OPENROUTER_SITE_URL=http://localhost
OPENROUTER_APP_NAME=ai-data-analyst-agents

ENV=local
ARTIFACTS_DIR=artifacts
LOG_LEVEL=INFO

# Streamlit auth (PostgreSQL)
AUTH_DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DB_NAME
# Optional fallback if AUTH_DATABASE_URL is unset
DATABASE_URL=
AUTH_PASSWORD_PEPPER=replace_with_a_long_random_secret
AUTH_PASSWORD_HASH_ITERATIONS=390000
AUTH_LOCKOUT_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
AUTH_SESSION_TTL_MIN=240
MAX_UPLOAD_MB=50

SQL_DEFAULT_QUERY_ROW_LIMIT=50000
SQL_INTROSPECTION_MAX_TABLES=200
SQL_PREVIEW_ROWS=10000
SECURITY_ENFORCE_READ_ONLY_SQL=true
SECURITY_ALLOW_RAW_ROWS_TO_LLM=false
SECURITY_MAX_ROWS_TO_LLM=25
SECURITY_USER_ERROR_MAX_CHARS=400
